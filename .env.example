# Immutable application image
CUSTOM_IMAGE=ghcr.io/loopjet-llc/loopjet-frappe-suite
CUSTOM_TAG=platform-v0.1.0
BUILD_PLATFORM=linux/amd64
SOURCE_MODE=upstream
PULL_POLICY=missing
RESTART_POLICY=unless-stopped
# Use `hostinger` when an existing Hostinger Traefik project owns ports 80/443.
STACK_MODE=local

# Local defaults only. Replace every secret before any internet-facing deploy.
DB_PASSWORD=change-me
ADMIN_PASSWORD=change-me

# Site names become production hostnames on the VPS.
# ERP_SITE is the canonical Frappe site. CRM_SITE and HELPDESK_SITE are public
# aliases for the same database so CRM, ERPNext, HR, and Helpdesk share records.
ERP_SITE=erp.localhost
CRM_SITE=crm.localhost
HELPDESK_SITE=helpdesk.localhost
MCP_SITE=mcp.localhost
FRAPPE_BASE_URL=http://erp.localhost:8080
MCP_RESOURCE_SERVER_URL=http://mcp.localhost:8090
MCP_ISSUER_URL=http://erp.localhost:8080
MCP_IMAGE=ghcr.io/loopjet-llc/loopjet-frappe-mcp
MCP_TAG=local
ERP_COMPANY="Loopjet LLC"
CRM_CREATE_CUSTOMER_DEAL_STATUS=Won

HTTP_PUBLISH_PORT=8080
HTTPS_PUBLISH_PORT=443
LETSENCRYPT_EMAIL=operations@example.com
SITES_RULE='Host(`erp.example.com`) || Host(`crm.example.com`) || Host(`helpdesk.example.com`)'
TRAEFIK_CERTRESOLVER=letsencrypt

# Production and Hostinger health checks use the public HTTPS endpoints.
# HEALTHCHECK_SCHEME=https
# HEALTHCHECK_PORT=443

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
